# Production API
NEXT_PUBLIC_BACKEND_API_URL=https://connitor.bengalurutechcommunity.com
# For local dev against local Python API:
#   NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8002


# Dev-only proxy target (optional; used by next.config rewrites if you leave NEXT_PUBLIC empty)
BACKEND_PROXY_URL=http://127.0.0.1:8002

# Demo mode: skip login UI, role switcher; sends x-demo-user-id to backend when DEMO_MODE=true there
NEXT_PUBLIC_DEMO_MODE=false

# In-browser mocks only (no backend). Use for static deploys without API.
NEXT_PUBLIC_USE_MOCK_API=false






