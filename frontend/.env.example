# Production API (e.g. https://app.bengalurutechcommunity.in)
# Leave empty in local dev to use BACKEND_PROXY_URL via Next.js rewrite
NEXT_PUBLIC_BACKEND_API_URL=https://app.bengalurutechcommunity.in

# Dev-only proxy target when NEXT_PUBLIC_BACKEND_API_URL is empty
BACKEND_PROXY_URL=http://localhost:8000

# Demo mode: skip login UI, role switcher; sends x-demo-user-id to backend when DEMO_MODE=true there
NEXT_PUBLIC_DEMO_MODE=false

# In-browser mocks only (no backend). Use for static deploys without API.
NEXT_PUBLIC_USE_MOCK_API=false
