PORT=8000
HOST=0.0.0.0

MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-user
MYSQL_PASSWORD=your-password
MYSQL_DB=hvts

# Encode @ in password as %40 in DATABASE_URL
DATABASE_URL=mysql+pymysql://user:pass@host:3306/hvts

JWT_SECRET=this_is_a_super_secret_key
JWT_EXPIRES_IN=1d

VISITOR_FORM_URL=http://localhost:3000/public-qr-visitor-form/

GCP_PROJECT_ID=client-hvts
GCP_BUCKET_NAME=hvts-dev
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json
GCP_PUBLIC_URL=https://storage.googleapis.com/hvts-dev

# Email OTP — ZeptoMail India (API + SMTP)
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USER=emailapikey
SMTP_PASSWORD=your-zeptomail-send-mail-token
SMTP_FROM=noreply@your-verified-domain.com
EMAIL_FROM_NAME=Connitor
EMAIL_PRODUCT_NAME=Hospital Visitor Tracking System

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=nowest

# WhatsApp — Meta Cloud API (recommended: Yes/No buttons + inbound webhooks)
NOTIFICATION_CHANNEL=whatsapp
WHATSAPP_PROVIDER=meta
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
# Aliases: WHATSAPP_API_BASE, WHATSAPP_API_KEY (for WHATSAPP_ACCESS_TOKEN)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
# Meta user tokens expire (often ~24h for test tokens). Regenerate in Meta Developer Console
# when you see 401 / "Session has expired" — check GET / meta_whatsapp_valid in API root config.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token
WHATSAPP_TEMPLATE_GATE_PASS=gate_pass_approved
WHATSAPP_TEMPLATE_NOTIFICATION=connitor_notification
# Doctor Yes/No approval — create in Meta Business Manager (see .env.example comments)
WHATSAPP_TEMPLATE_APPOINTMENT_APPROVAL=appointment_approval_request
# Create template in Meta → WhatsApp Manager → Message templates:
#   Name: appointment_approval_request
#   Category: UTILITY
#   Body: New appointment request from {{1}} on {{2}}. Code: {{3}}. Tap Yes or No.
#   Buttons: Quick reply "Yes" (index 0), Quick reply "No" (index 1)
# Add doctor phone (+91...) to API Setup → "To" test recipients before sending.
WHATSAPP_REPLY_API_KEY=your-secret-reply-key

# PyWhatKit fallback (WhatsApp Web automation; no interactive buttons)
# PYWHATKIT_CENTRAL_PHONE=8625877312
# PYWHATKIT_WAIT_TIME=40
# PYWHATKIT_TAB_CLOSE=false

# Twilio SMS (login OTP) and optional WhatsApp API fallback
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
TWILIO_WEBHOOK_URL=https://your-api.example.com/api/webhooks/twilio/sms
SMS_DEFAULT_COUNTRY_CODE=91

APP_TIMEZONE=Asia/Kolkata
# Use HVTS_TEST_MODE (not TEST_MODE — Windows often sets TEST_MODE globally)
HVTS_TEST_MODE=false
E2E_FIXED_OTP=123456
DEMO_MODE=false

# Public URLs (required in production / Lambda)
FRONTEND_URL=http://localhost:3000
# Use PUBLIC_* for links in emails/SMS when API runs locally but site is deployed
PUBLIC_FRONTEND_URL=https://your-public-frontend.example.com
# Comma-separated extra origins for CORS (e.g. Amplify staging: https://xxx.amplifyapp.com)
CORS_ALLOWED_ORIGINS=
PUBLIC_API_BASE_URL=https://your-public-api.example.com
NODE_ENV=development

# Optional: JSON secret in AWS Secrets Manager (Lambda). Keys = same names as below.
# HVTS_SECRETS_ARN=arn:aws:secretsmanager:ap-south-1:123456789:secret:hvts/prod

# Zoom — Server-to-Server OAuth (online appointments)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=your-hospital-zoom-user@domain.com
ZOOM_WEBHOOK_SECRET_TOKEN=

RATE_LIMIT_SMS_PER_HOUR=3
RATE_LIMIT_SKIP_IN_TEST_MODE=true

# Visitor pre-registration (AWS S3 media + OAuth)
AWS_S3_BUCKET=your-visitor-assets-bucket
VISITOR_JWT_EXPIRY_HOURS=168
EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/visitor/verify-email
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
VISITOR_OAUTH_REDIRECT_BASE=http://localhost:8001
