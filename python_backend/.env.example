PORT=8000
HOST=0.0.0.0

MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-user
MYSQL_PASSWORD=your-password
MYSQL_DB=hvts

# Encode @ in password as %40 in DATABASE_URL
DATABASE_URL=mysql+pymysql://user:pass@host:3306/hvts

JWT_SECRET=this_is_a_super_secret_key
JWT_EXPIRES_IN=1d

VISITOR_FORM_URL=http://localhost:3000/public-qr-visitor-form/

GCP_PROJECT_ID=client-hvts
GCP_BUCKET_NAME=hvts-dev
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json
GCP_PUBLIC_URL=https://storage.googleapis.com/hvts-dev

# Email OTP — ZeptoMail India (API + SMTP)
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1/email
SMTP_HOST=smtp.zeptomail.in
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_USER=emailapikey
SMTP_PASSWORD=your-zeptomail-send-mail-token
SMTP_FROM=noreply@your-verified-domain.com
EMAIL_FROM_NAME=Connitor
EMAIL_PRODUCT_NAME=Hospital Visitor Tracking System

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

WHATSAPP_API_URL=https://graph.facebook.com/v24.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_TEMPLATE_GATE_PASS=gate_pass_approved

NODE_ENV=development
# Use HVTS_TEST_MODE (not TEST_MODE — Windows often sets TEST_MODE globally)
HVTS_TEST_MODE=false
E2E_FIXED_OTP=123456
DEMO_MODE=false

RATE_LIMIT_SMS_PER_HOUR=3
RATE_LIMIT_SKIP_IN_TEST_MODE=true
